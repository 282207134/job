# =============================================================================
# 以下变量均为「可选」。未填写时：应用应能正常启动，仅对应能力（推送 / LiveKit / 等）不可用。
# Android 与 iOS 共用 Flutter 打包的 .env（pubspec assets）；与 AndroidManifest 里
# 单独的 Google Maps key 无冲突——iOS 原生 Maps 另见 ios/Flutter/*.xcconfig 的 GOOGLE_MAPS_IOS_KEY。
# =============================================================================

# OneSignal：https://onesignal.com → 应用 → Keys & IDs → App ID
ONESIGNAL_APP_ID=

# LiveKit：https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# 复制本文件为项目根目录 `.env` 后按需填写（勿把含密钥的 .env 提交到 Git）
