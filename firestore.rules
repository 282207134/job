rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // 友だちリンク: 関係者のみ読み書き
    match /friend_links/{linkId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.uids;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.uids &&
        request.resource.data.requested_by == request.auth.uid &&
        request.resource.data.uids is list &&
        request.resource.data.uids.size() == 2;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.uids;
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.uids;
    }

    // 1対1チャット（本番では participants のみに絞ることを推奨）
    match /directChats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    match /messages/{docId} {
      allow read, write: if request.auth != null;
    }

    match /events/{docId} {
      allow read, write: if request.auth != null;
    }

    match /chatrooms/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
