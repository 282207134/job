rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // 友だちリンク: 関係者のみ読み書き
    match /friend_links/{linkId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.uids;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.uids &&
        request.resource.data.requested_by == request.auth.uid &&
        request.resource.data.uids is list &&
        request.resource.data.uids.size() == 2;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.uids;
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.uids;
    }

    // 1対1チャット（本番では participants のみに絞ることを推奨）
    match /directChats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    match /messages/{docId} {
      allow read, write: if request.auth != null;
    }

    match /events/{docId} {
      allow read, write: if request.auth != null;
    }

    // 共享日历房间
    match /shared_calendars/{roomId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.member_uids;
      allow create: if request.auth != null &&
        request.resource.data.owner_uid == request.auth.uid &&
        request.auth.uid in request.resource.data.member_uids;
      allow update: if request.auth != null &&
        (
          request.auth.uid in resource.data.member_uids ||
          (
            exists(/databases/$(database)/documents/calendar_invites/$(roomId + "_" + request.auth.uid)) &&
            get(/databases/$(database)/documents/calendar_invites/$(roomId + "_" + request.auth.uid)).data.status == 'pending' &&
            get(/databases/$(database)/documents/calendar_invites/$(roomId + "_" + request.auth.uid)).data.to_uid == request.auth.uid &&
            request.auth.uid in request.resource.data.member_uids
          )
        );
      allow delete: if request.auth != null &&
        resource.data.owner_uid == request.auth.uid;
    }

    // 共享日历邀请
    match /calendar_invites/{inviteId} {
      // 邀请文档仅用于共享日历流程，先放宽为登录可读写，避免规则条件导致的误拒绝
      // 后续若需收紧，可基于 from_uid / to_uid 再细化。
      allow read, write: if request.auth != null;
    }

    match /chatrooms/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
